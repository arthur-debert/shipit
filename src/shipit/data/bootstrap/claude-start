#!/usr/bin/env bash
# claude-start — launch an isolated coordinator session. Installed and managed by
# `shipit install`.
#
# THIN by design (docs/prd/session-bootstrap.md, Layer D): mint a per-launch
# session id and `exec claude --worktree "<minted-id>" "$@"`. The `--worktree`
# flag fires shipit's WorktreeCreate hook, so the root session lands in its own
# provisioned Tree with the SessionStart activation (CLAUDE_ENV_FILE) live —
# isolated from every other session on this repo.
#
# Convenience only, never a requirement: `claude -w <name>` works identically
# without this file. The minted id carries the `sess-` prefix so a claude-start
# session is recognizable (the ADR-0027 name-prefix convention).
#
# Do not edit — `shipit install` overwrites this file.
set -euo pipefail

if ! command -v claude >/dev/null 2>&1; then
	echo "claude-start: the claude CLI is not on PATH — install Claude Code first." >&2
	exit 127
fi

# Session id: sortable UTC launch stamp + this launcher's PID — unique across
# concurrent launches on one host, no extra tooling needed.
exec claude --worktree "sess-$(date -u +%Y%m%d-%H%M%S)-$$" "$@"
