#!/usr/bin/env bash
# claude-start — compatibility shim over the generic `./agent-start` launcher
# (CDX01 #627). Installed and managed by `shipit install`.
#
# All launch logic lives in `agent-start` (the host strategy table +
# per-host launch functions; docs/dev/agent-host-seams.md) — this file only
# delegates, so existing muscle memory and docs keep working. Prefer
# `./agent-start claude [args...]`.
#
# Do not edit — `shipit install` overwrites this file.
set -euo pipefail

repo="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
if [ ! -x "$repo/agent-start" ]; then
	echo "claude-start: $repo/agent-start is missing or not executable — run 'shipit install' to (re)provision the managed launchers." >&2
	exit 127
fi

exec "$repo/agent-start" claude "$@"
