{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "pixi run shipit hook pretooluse"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "pixi run -e lint install-hooks"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "pixi run shipit hook sessionstart"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "pixi run shipit hook subagent-stop"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "pixi run shipit hook stop"
          }
        ]
      }
    ]
  }
}
